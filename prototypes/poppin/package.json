{
  "name": "poppin",
  "version": "0.1.0",
  "private": true,
  "description": "Poppin - public pop-up pages + live walk-in waitlist for pop-up service artists (permanent jewelry, lash, piercing).",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test:unit": "node --test test/unit/*.test.js",
    "test:e2e": "PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers playwright test",
    "test": "npm run test:unit && npm run test:e2e"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1"
  }
}
