# Copy to .env and fill in (never commit .env / real keys).
# The app reads plain environment variables; use `env $(cat .env | xargs) npm start`
# or your own loader.

# Anthropic API key. Without it, InkLine runs in clearly-labeled STUB mode.
ANTHROPIC_API_KEY=

# Vision model used by the real provider.
MODEL=claude-sonnet-5

# Set to "anthropic" (with a key present) to enable real transcription.
TRANSCRIBE_PROVIDER=

# Optional: HTTP port (default 3000).
# PORT=3000
